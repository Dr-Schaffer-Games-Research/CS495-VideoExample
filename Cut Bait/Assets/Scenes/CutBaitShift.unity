  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "You have two new duties:\n\n\t1. Factors 2C through 2E are marked as \n\t   
    low risk. One low-risk factor alone is \n\t    insufficient to confirm an email
    is a scam.\n\n\t2. For risk factors in section 3, you now must \n\t    examine
    links for validity. \n\n\t    Hover over a link/botton to reveal its URL.\n\t   
    Check this URL for violations of risk factor\n\t    3A and onward.\n\nBelow,
    I've included a link in this email which uses 'teenyurl.com,' a popular URL shortener
    used in scams. Thus, the link aligns with factor 3B. \n\nMatch the two to start
    your time for day.\n\t"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
