  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "You have two new duties:\n\n\t1. New features 3C, 3D, and 4C are low risk.
    \n\t    Same as before, find more risks for confirmation.\n\n\t2. For risk factors
    in section 4, you now must \n\t    examine attatchments for potential threat.
    \n\n\t    Examine these by their file types in search of \n              violations
    of risk factor 4A or 4B. In some cases, \n              you'll have to hover
    over attatchments to see their \n\t    file name, same as link URLs.\n\nBelow,
    I've attatched a \".exe\" file which aligns with factor 4A. \n\nMatch them and
    discard this email to start your time for day.\n\t"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
