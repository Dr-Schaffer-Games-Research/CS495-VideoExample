  m_text: "Dear customer, \n\nDue to strikes at our facilities, all outgoing packages
    in your area are experiencing shipping delays of 2-3 days. We're sorry for any
    incovenience.\n\nAs a work-around, some packages may have been transfered to
    new locations which are still operating normally. \n\nIf you'd like to check
    you package's status, please refer to the tracking service linked below.\n\n\n\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
