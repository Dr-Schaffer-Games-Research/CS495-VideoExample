  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Arnie Elloway, \n\nOur records show we have a package to be delivered
    to your address, yet it cannot be located in the appropriate warehouse.\n\nChances
    are your item(s) were flown in from abroad and either misplaced at the airport
    or in our storage facilities.\n\nIf you're not notified of this issue's resolution
    within the next week, please reply to this email or call our support number below
    to escalate:\n\n       - (882) 734-5159\n\nWe apologize for any inconvenience.
    Have a nice day."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
